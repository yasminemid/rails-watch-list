<%= link_to "Add a movie", new_list_bookmark_path(@list) %>
<div class="container mt-4">
<h1><%= @list.name %></h1>
  <h1 class="mb-4"><%= @list.name %></h1>

  <% if @list.bookmarks.empty? %>
    <p class="text-muted">No movies yet in this list.</p>
  <% else %>
    <div class="row">
      <% @list.bookmarks.each do |bookmark| %>
        <div class="col-md-4 mb-3">
          <div class="card h-100">
            <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="<%= bookmark.movie.title %>">
            <div class="card-body">
              <h5 class="card-title"><%= bookmark.movie.title %></h5>
              <p class="card-text"><%= bookmark.comment %></p>
              <%= button_to "Remove", bookmark_path(bookmark), method: :delete, class: "btn btn-outline-danger btn-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-primary mt-3" %>
</div>
